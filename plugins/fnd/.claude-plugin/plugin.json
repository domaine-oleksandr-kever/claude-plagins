{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "fnd",
  "displayName": "Foundation",
  "version": "0.28.0",
  "description": "Domaine Foundation skills for Claude Code — Agentic Assisted Development workflow for Shopify theme work.",
  "author": {
    "name": "Oleksandr Kever",
    "email": "oleksandr.kever@meetdomaine.com"
  },
  "license": "MIT",
  "keywords": ["shopify", "foundation", "domaine", "skills"],
  "mcpServers": {
    "chrome-devtools-mcp": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest", "--isolated"]
    },
    "atlassian": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.atlassian.com/v1/mcp"]
    },
    "shopify-dev-mcp": {
      "command": "npx",
      "args": ["-y", "@shopify/dev-mcp@latest"],
      "env": { "LIQUID": "true" }
    },
    "figma-dev-mode": {
      "type": "sse",
      "url": "http://127.0.0.1:3845/sse"
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "notion-mcp": {
      "type": "http",
      "url": "https://mcp.notion.com/mcp"
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"fnd plugin root: ${CLAUDE_PLUGIN_ROOT}\"; for f in comment-discipline plugin-feedback task-workspace; do cat \"${CLAUDE_PLUGIN_ROOT}/hooks/$f.md\" 2>/dev/null; done; if [ -f shopify.theme.toml ] || [ -f .env ]; then cat \"${CLAUDE_PLUGIN_ROOT}/hooks/store-access.md\" 2>/dev/null; fi; [ \"${FND_LEAN:-1}\" = \"0\" ] || cat \"${CLAUDE_PLUGIN_ROOT}/hooks/lean-code.md\" 2>/dev/null; true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ \"${FND_CTX_MONITOR:-1}\" = \"0\" ] || node \"${CLAUDE_PLUGIN_ROOT}/hooks/context-stats.cjs\" || true"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/subagent-conventions.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/no-ai-attribution.sh\""
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/no-verify-bypass.sh\""
          }
        ]
      }
    ]
  }
}
